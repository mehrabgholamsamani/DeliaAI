NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://receptionist:receptionist@localhost:5433/ai_receptionist?schema=public
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_EMBEDDING_MODEL=text-embedding-004
# Disabled by default. Cloud TTS uses Application Default Credentials, never a browser key.
GOOGLE_TTS_ENABLED=false
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_LANGUAGE_CODE=en-US
# App-enforced monthly cap; leave well below Google's free quota.
GOOGLE_TTS_MONTHLY_CHARACTER_LIMIT=100000
GOOGLE_STT_ENABLED=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_STT_LANGUAGE_CODE=en-US
ADMIN_API_TOKEN=
# Google sign-in is disabled until both values are set. Keep the secret server-only.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# Leave empty locally to use Vite's same-origin proxy. In Vercel, set this to the public API URL
# so both HTTP requests and Socket.IO connect directly to the Render API.
VITE_API_ORIGIN=
