{
  "name": "ai-receptionist-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "npm run dev --workspace=@receptionist/api",
    "dev:web": "npm run dev --workspace=@receptionist/web",
    "build:platform": "npm run build --workspace=@receptionist/contracts && npm run build --workspace=@receptionist/prompts && npm run build --workspace=@receptionist/api && npm run build --workspace=@receptionist/web",
    "typecheck": "npm run build --workspace=@receptionist/contracts && npm run typecheck --workspace=@receptionist/prompts && npm run typecheck --workspace=@receptionist/api && npm run typecheck --workspace=@receptionist/web",
    "lint": "eslint apps packages --max-warnings=0",
    "test": "vitest run --root apps/api --exclude=src/**/*.integration.spec.ts",
    "test:integration": "vitest run --root apps/api src/crm/crm.integration.spec.ts",
    "format": "prettier --write apps packages docs package.json docker-compose.yml",
    "format:check": "prettier --check apps packages docs package.json docker-compose.yml",
    "db:generate": "npm run prisma:generate --workspace=@receptionist/api",
    "db:migrate": "npm run prisma:migrate --workspace=@receptionist/api",
    "db:deploy": "npx prisma migrate deploy --schema apps/api/prisma/schema.prisma",
    "dev:legacy": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/src/index.ts",
    "mailpit": ".\\tools\\mailpit\\mailpit.exe --smtp 127.0.0.1:1025 --listen 127.0.0.1:8025",
    "build": "npm run build:platform",
    "build:client": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node apps/api/dist/main.js",
    "verify:release": "npm run lint && npm run typecheck && npm run build:platform && npm test && npm run test:integration",
    "build:legacy": "npm run build:client && npm run build:server",
    "start:legacy": "node dist/server/index.js",
    "test:api": "vitest run --root . tests/api.test.ts",
    "test:smoke": "playwright test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph": "^1.4.8",
    "@nestjs/platform-socket.io": "^11.1.28",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.28",
    "@types/cookie-parser": "^1.4.10",
    "@types/luxon": "^3.7.1",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "lucide-react": "^0.468.0",
    "luxon": "^3.7.2",
    "mongoose": "^8.9.2",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.60.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "mongodb-memory-server": "^11.2.0",
    "postcss": "^8.4.49",
    "prettier": "^3.9.5",
    "sass": "^1.83.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.8"
  }
}
